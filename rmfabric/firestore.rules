rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ─────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/RM_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/RM_users/$(request.auth.uid)).data.role == "admin";
    }

    function isSeller() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/RM_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/RM_users/$(request.auth.uid)).data.role == "seller";
    }

    function isDayClosed(dayId) {
      return exists(/databases/$(database)/documents/RM_days/$(dayId)) &&
        get(/databases/$(database)/documents/RM_days/$(dayId)).data.isClosed == true;
    }

    // ─── RM_users ─────────────────────────────────────────────

    match /RM_users/{userId} {

      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      allow update: if isAdmin();

      allow delete: if false;
    }

    // ─── RM_products ──────────────────────────────────────────

    match /RM_products/{productId} {

      allow read: if isAuthenticated();

      allow create: if isAdmin();

      // Admin edits products
      // Sellers allowed ONLY for stock deduction during sale
      allow update: if isAdmin() || isSeller();

      allow delete: if false;
    }

    // ─── RM_sales ─────────────────────────────────────────────

    match /RM_sales/{saleId} {

      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        !isDayClosed(request.resource.data.dayId) &&
        (request.resource.data.sellerId == request.auth.uid || isAdmin());

      allow update, delete: if false;
    }

    // ─── RM_expenses ──────────────────────────────────────────

    match /RM_expenses/{expenseId} {

      allow read: if isAdmin();

      allow create: if isAdmin() &&
        !isDayClosed(request.resource.data.dayId);

      allow update, delete: if false;
    }

    // ─── RM_days ──────────────────────────────────────────────

    match /RM_days/{dayId} {

      allow read: if isAuthenticated();

      allow create, update: if isAdmin();

      allow delete: if false;
    }

    // ─── RM_reports_daily ─────────────────────────────────────

    match /RM_reports_daily/{date} {

      allow read: if isAdmin();

      allow create, update: if isAdmin();

      allow delete: if false;
    }

    // ─── RM_reports_weekly ────────────────────────────────────

    match /RM_reports_weekly/{weekId} {

      allow read, create, update: if isAdmin();

      allow delete: if false;
    }

    // ─── RM_reports_monthly ───────────────────────────────────

    match /RM_reports_monthly/{monthId} {

      allow read, create, update: if isAdmin();

      allow delete: if false;
    }

    // ─── RM_stock_movements ───────────────────────────────────

    match /RM_stock_movements/{movementId} {

      allow read: if isAuthenticated();

      // Sellers create movement when they sell
      // Admin creates movement when restocking
      allow create: if isAuthenticated();

      allow update, delete: if false;
    }

  }
}